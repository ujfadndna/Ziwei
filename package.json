{
  "name": "ziwei-pro",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@10.29.3",
  "scripts": {
    "dev": "pnpm --filter @ziwei/web dev",
    "dev:desktop": "concurrently -k \"pnpm --filter @ziwei/web dev -- --host 127.0.0.1 --port 5173\" \"wait-on tcp:127.0.0.1:5173 && pnpm --filter @ziwei/desktop dev\"",
    "build": "pnpm -r --if-present build",
    "build:desktop": "pnpm --filter @ziwei/web build && pnpm --filter @ziwei/desktop build",
    "pack:win": "pnpm run build:desktop && pnpm --filter @ziwei/desktop pack:win",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -b"
  },
  "devDependencies": {
    "@types/node": "^25.2.3",
    "concurrently": "^9.2.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18",
    "wait-on": "^8.0.4"
  }
}
