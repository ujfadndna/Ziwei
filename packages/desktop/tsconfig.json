{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "lib": ["ES2022"],
    "types": ["node", "electron"],
    "rootDir": "./src",
    "outDir": "./dist",
    "noEmit": false,
    "verbatimModuleSyntax": false,
    "isolatedModules": false
  },
  "include": ["src"]
}
